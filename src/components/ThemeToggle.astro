---
// ThemeToggle.astro — Sun / Moon icon that toggles dark/light mode
// The toggle script lives in BaseLayout to run after FOUC prevention.
// This component just provides the button markup.
---

<button
  id="theme-toggle"
  aria-label="Toggle color theme"
  title="Toggle color theme"
  class="flex items-center justify-center w-8 h-8 rounded-lg
         text-slate-500 dark:text-slate-500
         hover:text-slate-900 dark:hover:text-slate-200
         hover:bg-slate-100 dark:hover:bg-slate-800/50
         transition-all duration-200 focus-visible:outline-none
         focus-visible:ring-2 focus-visible:ring-cyan-500"
>
  <!-- Sun — shown in dark mode; click → switch to light -->
  <svg
    id="icon-sun"
    class="w-4 h-4 hidden dark:block"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343
         6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16
         12a4 4 0 11-8 0 4 4 0 018 0z"
    />
  </svg>

  <!-- Moon — shown in light mode; click → switch to dark -->
  <svg
    id="icon-moon"
    class="w-4 h-4 block dark:hidden"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003
         9.003 0 008.354-5.646z"
    />
  </svg>
</button>
