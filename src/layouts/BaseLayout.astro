---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'IT Professional & Internet Entrepreneur. Writing about tech, online business, and 8+ years of building things on the internet.',
} = Astro.props;

const navLinks = [
  { href: '/writing',  label: 'Writing'  },
  { href: '/journey',  label: 'Journey'  },
  { href: '/ventures', label: 'Ventures' },
];

const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === 'Home' ? 'Mohtashim' : `${title} — Mohtashim`}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Fira+Code:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>

<body class="flex flex-col min-h-screen">

  <!-- ═══════════════════════════ NAV ═══════════════════════════ -->
  <header class="sticky top-0 z-50 border-b border-slate-800/60 bg-[#020617]/90 backdrop-blur-md">
    <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">

      <!-- Wordmark -->
      <a href="/" class="font-mono text-sm font-semibold text-slate-300 hover:text-cyan-400 transition-colors duration-200 tracking-tight">
        mohtashim<span class="text-cyan-400">.</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden sm:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm transition-colors duration-200 ${
              path === link.href || path.startsWith(link.href + '/')
                ? 'text-cyan-400 font-medium'
                : 'text-slate-500 hover:text-slate-200'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="sm:hidden p-1.5 -mr-1.5 text-slate-500 hover:text-slate-200 transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile drawer -->
    <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-800/60">
      <div class="max-w-3xl mx-auto px-6 py-5 flex flex-col gap-5">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm transition-colors ${
              path === link.href || path.startsWith(link.href + '/')
                ? 'text-cyan-400 font-medium'
                : 'text-slate-400 hover:text-slate-200'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════ MAIN ═══════════════════════════ -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- ═══════════════════════════ FOOTER ═══════════════════════════ -->
  <footer class="border-t border-slate-800/60 py-12 px-6 mt-10">
    <div class="max-w-3xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-mono text-xs text-slate-600">Mohtashim · IT Professional & Internet Entrepreneur</p>
        <p class="font-mono text-xs text-slate-700 mt-1">Writing from experience, not theory. Since 2018.</p>
      </div>
      <p class="font-mono text-xs text-slate-800">© {new Date().getFullYear()}</p>
    </div>
  </footer>

  <!-- Mobile menu script -->
  <script>
    const toggle   = document.getElementById('menu-toggle');
    const menu     = document.getElementById('mobile-menu');
    const iconOpen  = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    toggle?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
    });

    // Close on nav link click
    menu?.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      })
    );
  </script>

  <!-- Scroll reveal -->
  <script>
    const els = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      }),
      { threshold: 0.1 }
    );
    els.forEach(el => obs.observe(el));
  </script>

</body>
</html>
