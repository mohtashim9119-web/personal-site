---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by year
const byYear: Record<number, typeof posts> = {};
for (const post of posts) {
  const y = post.data.pubDate.getFullYear();
  if (!byYear[y]) byYear[y] = [];
  byYear[y].push(post);
}
const years = (Object.keys(byYear) as unknown as number[]).sort((a, b) => Number(b) - Number(a));

function fmtShort(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="Writing"
  description="Essays on IT, internet business, and what 8+ years of building things on the internet actually teaches you."
>
  <div class="max-w-3xl mx-auto px-6 pt-20 pb-28">

    <!-- Page header -->
    <header class="mb-16 reveal">
      <p class="font-mono text-xs text-cyan-400 uppercase tracking-[0.22em] mb-4">Writing</p>
      <h1 class="text-3xl sm:text-4xl font-black text-slate-100 mb-5 tracking-tight">
        Essays & Reflections
      </h1>
      <p class="text-[17px] text-slate-500 leading-relaxed max-w-xl">
        Honest writing about IT infrastructure, internet business, and what building things online since 2018 has actually taught me.
        No courses. No fluff. Just the real version.
      </p>
    </header>

    <!-- Post list -->
    {posts.length === 0 ? (
      <div class="text-slate-600 text-sm py-12 border-t border-slate-800/70">
        No essays published yet. Check back soon.
      </div>
    ) : (
      <div class="space-y-16 reveal">
        {years.map(year => (
          <section>
            <!-- Year header -->
            <div class="flex items-center gap-4 mb-8">
              <h2 class="font-mono text-xs text-slate-700 uppercase tracking-[0.2em]">{year}</h2>
              <div class="flex-1 h-px bg-slate-800/80"></div>
              <span class="font-mono text-xs text-slate-800">{byYear[year].length} {byYear[year].length === 1 ? 'post' : 'posts'}</span>
            </div>

            <!-- Posts in year -->
            <div class="space-y-10">
              {byYear[year].map(post => (
                <article class="group grid sm:grid-cols-[5.5rem_1fr] gap-2 sm:gap-6">

                  <!-- Date -->
                  <time class="font-mono text-xs text-slate-600 sm:pt-1 shrink-0">
                    {fmtShort(post.data.pubDate)}
                  </time>

                  <!-- Content -->
                  <div>
                    <h3 class="text-base font-bold text-slate-200 leading-snug group-hover:text-cyan-400 transition-colors duration-200">
                      <a href={`/writing/${post.slug}`}>{post.data.title}</a>
                    </h3>

                    <p class="mt-2 text-sm text-slate-500 leading-relaxed">
                      {post.data.description}
                    </p>

                    {post.data.tags.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-1.5">
                        {post.data.tags.map(tag => (
                          <span class="font-mono text-[11px] text-slate-700 bg-slate-900/60 border border-slate-800/80 px-2 py-0.5 rounded">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
