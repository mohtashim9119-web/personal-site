---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Home">

  <!-- ══════════════════════════════════════════════════════════════
       HERO — Asymmetric split: 60 % copy | 40 % visual
  ══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">

    <!-- ── Background depth glows ───────────────────────────── -->
    <!-- Cyan: top-left corner -->
    <div class="glow-blob -top-48 -left-48 h-[540px] w-[540px]
                bg-cyan-500/[0.07] dark:bg-cyan-500/[0.09]"></div>
    <!-- Blue: upper-right, near avatar column -->
    <div class="glow-blob -top-20 right-0 h-96 w-96
                bg-blue-600/[0.07] dark:bg-blue-600/[0.08]
                translate-x-1/3"></div>
    <!-- Violet: lower centre-right -->
    <div class="glow-blob bottom-0 right-1/4 h-72 w-72
                bg-violet-600/[0.05] dark:bg-violet-600/[0.06]
                translate-y-1/2"></div>

    <!-- ── Content wrapper ───────────────────────────────────── -->
    <div class="relative z-10 max-w-6xl mx-auto px-6
                pt-20 pb-24 sm:pt-24 sm:pb-28 lg:pt-28 lg:pb-32">

      <div class="grid grid-cols-1 items-center gap-14
                  lg:grid-cols-[3fr_2fr] lg:gap-16">

        <!-- ════════════════════════
             LEFT: COPY (60 %)
        ════════════════════════ -->
        <div>

          <!-- Status badge -->
          <div class="mb-9 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5
                      border border-slate-200 dark:border-slate-700/60
                      bg-slate-100/80 dark:bg-slate-800/60
                      font-mono text-xs
                      text-slate-600 dark:text-slate-400">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full
                           bg-emerald-400 opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
            </span>
            IT Professional · Internet Entrepreneur · Since 2018
          </div>

          <!-- Headline — text-balance for elegant wrapping -->
          <h1 class="text-balance font-black tracking-tight leading-[1.1]
                     text-4xl sm:text-5xl lg:text-[3.4rem]
                     text-slate-900 dark:text-slate-100 mb-6">
            Building online since&nbsp;
            <span class="bg-gradient-to-r from-cyan-400 to-blue-500
                         bg-clip-text text-transparent">2018.</span>
            <br class="hidden sm:block" />
            Some worked.
            <br />
            <span class="text-slate-400 dark:text-slate-500 font-extrabold">
              All of it counts.
            </span>
          </h1>

          <!-- Body copy -->
          <div class="space-y-4 text-[17px] leading-[1.85]
                      text-slate-500 dark:text-slate-400 max-w-xl">
            <p>
              I'm <span class="font-semibold text-slate-800 dark:text-slate-200">Mohtashim</span> — a self-employed IT professional and internet entrepreneur
              operating at the intersection of infrastructure and online business.
              Not as a consultant who reads case studies, but as someone who has
              built, shipped, failed, and rebuilt things across both disciplines for nearly a decade.
            </p>
            <p>
              Eight-plus years generates a lot of signal. This site is where I
              publish the distilled version — the mechanics, the failures, the
              pivots, and the things that actually moved the needle.
            </p>
          </div>

          <!-- CTA row -->
          <div class="mt-10 flex flex-wrap items-center gap-4">

            <!-- Primary CTA: gradient button -->
            <a href="/writing"
               class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5
                      bg-gradient-to-r from-cyan-400 to-blue-500
                      text-slate-950 font-bold text-sm
                      shadow-lg shadow-cyan-500/20 dark:shadow-cyan-500/15
                      hover:from-cyan-300 hover:to-blue-400
                      hover:shadow-cyan-500/30 dark:hover:shadow-cyan-500/25
                      transition-all duration-200 hover:scale-[1.03] group">
              Read the essays
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <!-- Secondary CTAs -->
            <a href="/journey"
               class="text-sm font-medium
                      text-slate-500 dark:text-slate-500
                      hover:text-cyan-600 dark:hover:text-cyan-400
                      transition-colors duration-200">
              My story →
            </a>
            <a href="/ventures"
               class="text-sm font-medium
                      text-slate-500 dark:text-slate-500
                      hover:text-cyan-600 dark:hover:text-cyan-400
                      transition-colors duration-200">
              Ventures →
            </a>
          </div>

          <!-- Stat strip -->
          <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4
                      pt-10 border-t border-slate-200/80 dark:border-slate-800/60">
            <div>
              <p class="font-black text-2xl
                        bg-gradient-to-r from-cyan-400 to-blue-500
                        bg-clip-text text-transparent">8+</p>
              <p class="font-mono text-[11px] uppercase tracking-widest mt-0.5
                        text-slate-500 dark:text-slate-600">Years in IT</p>
            </div>
            <div class="h-8 w-px bg-slate-200 dark:bg-slate-800"></div>
            <div>
              <p class="font-black text-2xl
                        bg-gradient-to-r from-cyan-400 to-blue-500
                        bg-clip-text text-transparent">2018</p>
              <p class="font-mono text-[11px] uppercase tracking-widest mt-0.5
                        text-slate-500 dark:text-slate-600">Online Since</p>
            </div>
            <div class="h-8 w-px bg-slate-200 dark:bg-slate-800"></div>
            <div>
              <p class="font-black text-2xl
                        bg-gradient-to-r from-cyan-400 to-blue-500
                        bg-clip-text text-transparent">Multi</p>
              <p class="font-mono text-[11px] uppercase tracking-widest mt-0.5
                        text-slate-500 dark:text-slate-600">Businesses Built</p>
            </div>
            <div class="h-8 w-px bg-slate-200 dark:bg-slate-800"></div>
            <div>
              <p class="font-black text-2xl text-rose-400 dark:text-rose-400">0</p>
              <p class="font-mono text-[11px] uppercase tracking-widest mt-0.5
                        text-slate-500 dark:text-slate-600">Theories Used</p>
            </div>
          </div>
        </div>

        <!-- ════════════════════════
             RIGHT: VISUAL (40 %)
        ════════════════════════ -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative w-full max-w-[340px] mx-auto">

            <!-- Soft radial glow behind avatar -->
            <div class="absolute inset-0 scale-110
                        bg-[radial-gradient(ellipse_at_center,rgba(34,211,238,0.12)_0%,transparent_68%)]
                        dark:bg-[radial-gradient(ellipse_at_center,rgba(34,211,238,0.18)_0%,transparent_68%)]
                        blur-2xl"></div>

            <!-- Secondary blue glow offset -->
            <div class="absolute inset-0 translate-x-6 translate-y-8 scale-90
                        bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.10)_0%,transparent_65%)]
                        dark:bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.15)_0%,transparent_65%)]
                        blur-2xl"></div>

            <!-- Avatar image -->
            <img
              src="/avatar.svg"
              alt="Mohtashim — geometric avatar"
              width="340"
              height="340"
              class="relative z-10 w-full drop-shadow-2xl
                     select-none rounded-full
                     ring-1 ring-slate-200/20 dark:ring-slate-700/30"
            />

            <!-- Floating badge — top right of avatar -->
            <div class="absolute -top-3 -right-4 z-20
                        rounded-full px-3 py-1.5
                        border border-slate-200/80 dark:border-slate-700/60
                        bg-white/90 dark:bg-slate-900/80
                        backdrop-blur-sm shadow-sm
                        font-mono text-[11px]
                        text-slate-600 dark:text-slate-400">
              <span class="text-emerald-500 dark:text-emerald-400 mr-1.5">●</span>Building
            </div>

            <!-- Floating badge — bottom left of avatar -->
            <div class="absolute -bottom-3 -left-4 z-20
                        rounded-full px-3 py-1.5
                        border border-slate-200/80 dark:border-slate-700/60
                        bg-white/90 dark:bg-slate-900/80
                        backdrop-blur-sm shadow-sm
                        font-mono text-[11px]
                        text-slate-600 dark:text-slate-400">
              Since&nbsp;<span class="bg-gradient-to-r from-cyan-500 to-blue-500
                                      bg-clip-text text-transparent font-bold">2018</span>
            </div>
          </div>
        </div>

      </div><!-- /grid -->
    </div><!-- /content wrapper -->
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       DIVIDER
  ══════════════════════════════════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-6">
    <div class="section-rule"></div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       LATEST WRITING
  ══════════════════════════════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">

    <div class="flex items-center justify-between mb-12">
      <span class="font-mono text-xs uppercase tracking-[0.2em]
                   text-slate-500 dark:text-slate-600">Latest Writing</span>
      <a href="/writing"
         class="font-mono text-xs
                text-slate-400 dark:text-slate-700
                hover:text-cyan-600 dark:hover:text-cyan-400
                transition-colors duration-200">
        All posts →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="text-sm text-slate-500 dark:text-slate-600">
        No essays published yet. First one coming soon.
      </p>
    ) : (
      <div class="space-y-12">
        {posts.map((post, i) => (
          <article class={i !== 0 ? 'pt-12 border-t border-slate-200/80 dark:border-slate-800/50' : ''}>

            <time class="block font-mono text-xs mb-3
                         text-slate-400 dark:text-slate-600">
              {fmtDate(post.data.pubDate)}
            </time>

            <h2 class="text-xl font-bold leading-snug mb-3
                       text-slate-900 dark:text-slate-100">
              <a href={`/writing/${post.slug}`}
                 class="hover:text-cyan-600 dark:hover:text-cyan-400
                        transition-colors duration-200">
                {post.data.title}
              </a>
            </h2>

            <p class="text-base leading-relaxed mb-4 max-w-xl
                      text-slate-500 dark:text-slate-500">
              {post.data.description}
            </p>

            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map(tag => (
                  <span class="font-mono text-[11px] px-2 py-0.5 rounded
                               bg-slate-100 dark:bg-slate-900/60
                               border border-slate-200 dark:border-slate-800
                               text-slate-500 dark:text-slate-700">
                    #{tag}
                  </span>
                ))}
              </div>
            )}

            <a href={`/writing/${post.slug}`}
               class="inline-flex items-center gap-1.5 text-xs font-medium
                      text-slate-400 dark:text-slate-600
                      hover:text-cyan-600 dark:hover:text-cyan-400
                      transition-colors duration-200 group">
              Read essay
              <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       QUICK-LINK GRID
  ══════════════════════════════════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-6 pb-24">
    <div class="section-rule mb-12"></div>

    <div class="grid sm:grid-cols-3 gap-4">

      <a href="/writing"
         class="group block p-6 rounded-xl
                border border-slate-200/80 dark:border-slate-800/70
                hover:border-cyan-300/60 dark:hover:border-slate-700
                bg-white/50 dark:bg-transparent
                transition-all duration-200 hover:-translate-y-0.5">
        <p class="font-mono text-[11px] uppercase tracking-wider mb-2
                  text-slate-500 dark:text-slate-600">Writing</p>
        <p class="text-sm leading-relaxed
                  text-slate-600 dark:text-slate-400
                  group-hover:text-slate-900 dark:group-hover:text-slate-300
                  transition-colors duration-200">
          Essays on IT, internet business, and what 8+ years in the trenches teaches you.
        </p>
      </a>

      <a href="/journey"
         class="group block p-6 rounded-xl
                border border-slate-200/80 dark:border-slate-800/70
                hover:border-cyan-300/60 dark:hover:border-slate-700
                bg-white/50 dark:bg-transparent
                transition-all duration-200 hover:-translate-y-0.5">
        <p class="font-mono text-[11px] uppercase tracking-wider mb-2
                  text-slate-500 dark:text-slate-600">Journey</p>
        <p class="text-sm leading-relaxed
                  text-slate-600 dark:text-slate-400
                  group-hover:text-slate-900 dark:group-hover:text-slate-300
                  transition-colors duration-200">
          A raw, transparent timeline of business wins, failures, and pivots since 2018.
        </p>
      </a>

      <a href="/ventures"
         class="group block p-6 rounded-xl
                border border-slate-200/80 dark:border-slate-800/70
                hover:border-cyan-300/60 dark:hover:border-slate-700
                bg-white/50 dark:bg-transparent
                transition-all duration-200 hover:-translate-y-0.5">
        <p class="font-mono text-[11px] uppercase tracking-wider mb-2
                  text-slate-500 dark:text-slate-600">Ventures</p>
        <p class="text-sm leading-relaxed
                  text-slate-600 dark:text-slate-400
                  group-hover:text-slate-900 dark:group-hover:text-slate-300
                  transition-colors duration-200">
          The actual businesses I've started — active, exited, and the ones that failed.
        </p>
      </a>

    </div>
  </div>

</BaseLayout>
