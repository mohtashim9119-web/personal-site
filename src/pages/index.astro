---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Home">

  <!-- ══════════════════════════════════════
       MANIFESTO / INTRO
  ══════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 pt-20 sm:pt-28 pb-20">

    <p class="font-mono text-xs text-cyan-400 uppercase tracking-[0.22em] mb-8">
      IT Professional · Internet Entrepreneur · Since 2018
    </p>

    <h1 class="text-3xl sm:text-4xl font-black text-slate-100 leading-[1.2] mb-8 tracking-tight">
      I've been building things online since 2018.<br />
      Some worked. Most didn't.<br />
      <span class="text-slate-500">All of it counts.</span>
    </h1>

    <div class="space-y-5 text-[17px] text-slate-400 leading-[1.85] max-w-2xl">
      <p>
        I'm Mohtashim. I work at the intersection of IT infrastructure and internet business —
        as a practitioner, not a theorist. I've run networks, secured systems, and managed servers
        for clients across multiple countries. I've also built online businesses from zero,
        watched some of them scale, and watched others collapse completely.
      </p>
      <p>
        Eight-plus years does something to you. It strips away most of the received wisdom
        you started with, and replaces it with something slower and more useful:
        a calibrated understanding of what actually works, and why.
      </p>
      <p>
        This is where I write about that — the technology, the business models, the psychology of
        building things, and the honest accounting of what I've tried, won, and lost.
        No courses. No affiliate links. Just the unfiltered version.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-6">
      <a
        href="/writing"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 hover:text-cyan-300 transition-colors group"
      >
        Read the essays
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="/journey" class="text-sm text-slate-600 hover:text-slate-400 transition-colors">
        My story →
      </a>
      <a href="/ventures" class="text-sm text-slate-600 hover:text-slate-400 transition-colors">
        Ventures →
      </a>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <div class="section-rule"></div>
  </div>

  <!-- ══════════════════════════════════════
       LATEST WRITING
  ══════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">

    <div class="flex items-center justify-between mb-12">
      <span class="font-mono text-xs text-slate-600 uppercase tracking-[0.2em]">Latest Writing</span>
      <a href="/writing" class="font-mono text-xs text-slate-700 hover:text-cyan-400 transition-colors">
        All posts →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="text-slate-600 text-sm">No posts published yet. First essay coming soon.</p>
    ) : (
      <div class="space-y-12">
        {posts.map((post, i) => (
          <article class={`group ${i !== 0 ? 'pt-12 border-t border-slate-800/50' : ''}`}>
            <time class="font-mono text-xs text-slate-600 block mb-3">
              {fmtDate(post.data.pubDate)}
            </time>
            <h2 class="text-xl font-bold text-slate-100 leading-snug mb-3">
              <a
                href={`/writing/${post.slug}`}
                class="hover:text-cyan-400 transition-colors duration-200"
              >
                {post.data.title}
              </a>
            </h2>
            <p class="text-slate-500 leading-relaxed text-base mb-4 max-w-xl">
              {post.data.description}
            </p>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map(tag => (
                  <span class="font-mono text-[11px] text-slate-700 bg-slate-900/60 border border-slate-800 px-2 py-0.5 rounded">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
            <a
              href={`/writing/${post.slug}`}
              class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-600 hover:text-cyan-400 transition-colors group/link"
            >
              Read essay
              <svg class="w-3 h-3 group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- ══════════════════════════════════════
       QUICK LINKS BAR
  ══════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-6 pb-24">
    <div class="section-rule mb-12"></div>
    <div class="grid sm:grid-cols-3 gap-4">

      <a href="/writing" class="group block p-6 border border-slate-800/70 rounded-xl hover:border-slate-700 transition-colors">
        <p class="font-mono text-[11px] text-slate-600 uppercase tracking-wider mb-2">Writing</p>
        <p class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors leading-relaxed">
          Essays on IT, internet business, and what 8+ years in the trenches teaches you.
        </p>
      </a>

      <a href="/journey" class="group block p-6 border border-slate-800/70 rounded-xl hover:border-slate-700 transition-colors">
        <p class="font-mono text-[11px] text-slate-600 uppercase tracking-wider mb-2">Journey</p>
        <p class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors leading-relaxed">
          A raw, transparent timeline of business wins, failures, and pivots since 2018.
        </p>
      </a>

      <a href="/ventures" class="group block p-6 border border-slate-800/70 rounded-xl hover:border-slate-700 transition-colors">
        <p class="font-mono text-[11px] text-slate-600 uppercase tracking-wider mb-2">Ventures</p>
        <p class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors leading-relaxed">
          The actual businesses I've started — active, exited, and the ones that failed.
        </p>
      </a>

    </div>
  </div>

</BaseLayout>
