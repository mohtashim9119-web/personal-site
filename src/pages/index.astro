---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Building online since 2018. IT infrastructure, internet businesses, and the unfiltered reality of what works in the trenches."
>

  <!-- ═══════════════════════════════════════════ -->
  <!--  HERO                                       -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-20">
    <p class="text-xs font-mono tracking-widest text-cloudy uppercase mb-6">— Personal Chronicle</p>
    <h1 class="text-4xl md:text-5xl xl:text-6xl font-serif font-semibold leading-tight text-dark-accent dark:text-pampas mb-8">
      Building online since&nbsp;2018.<br />
      Some worked.<br />
      Most didn't.<br />
      <span class="text-crail">All of it counts.</span>
    </h1>
    <p class="text-lg leading-relaxed text-cloudy dark:text-cloudy max-w-xl mb-10">
      8+ years in IT. Multiple ventures. No filtered highlight reel — just the raw accounting of what actually happens when you build real things on the internet.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="/writing"
        class="inline-flex items-center gap-2 px-6 py-3 bg-crail hover:bg-crail-dark text-white font-sans font-medium text-sm rounded transition-colors duration-200"
      >
        Read the writing
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a
        href="/journey"
        class="inline-flex items-center gap-2 px-6 py-3 text-crail font-sans font-medium text-sm hover:text-crail-dark transition-colors duration-200"
      >
        The journey →
      </a>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  STATS ROW                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-cloudy/20 dark:bg-cloudy/10 border border-cloudy/30 dark:border-cloudy/15 rounded">
      {[
        { label: '8+ Years', sub: 'in IT' },
        { label: 'Since 2018', sub: 'Online' },
        { label: 'Multiple', sub: 'Ventures' },
        { label: '0', sub: 'Theories Used' },
      ].map(stat => (
        <div class="bg-warm-white dark:bg-dark-bg px-6 py-6 text-center">
          <div class="text-lg font-serif font-semibold text-dark-accent dark:text-pampas">{stat.label}</div>
          <div class="text-xs font-mono text-cloudy mt-1 uppercase tracking-wide">{stat.sub}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  MANIFESTO                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-xs font-mono tracking-widest text-cloudy uppercase mb-8">— Manifesto</p>
    <blockquote class="text-2xl md:text-3xl font-serif font-medium leading-relaxed text-dark-accent dark:text-pampas">
      I don't consult from theory.{' '}
      <span class="text-cloudy dark:text-cloudy">I operate from experience.</span>{' '}
      Over the last 8+ years, I've built IT infrastructure, launched internet businesses, and watched ideas scale — and collapse.{' '}
      <span class="italic">This is my unfiltered accounting of what actually works in the trenches.</span>
    </blockquote>
    <div class="mt-10 w-12 h-0.5 bg-crail"></div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  WINS & SCARS                               -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-xs font-mono tracking-widest text-cloudy uppercase mb-4">— The Battlefield</p>
    <h2 class="text-3xl font-serif font-semibold text-dark-accent dark:text-pampas mb-12">Wins &amp; Scars</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Win Card -->
      <div class="bg-pampas dark:bg-dark-bg-alt border border-cloudy/30 dark:border-cloudy/15 rounded p-8 space-y-5">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-full bg-crail/10 flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-crail" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <span class="text-xs font-mono tracking-widest text-crail uppercase">The Win</span>
        </div>
        <h3 class="text-xl font-serif font-semibold text-dark-accent dark:text-pampas">The Scaling Win</h3>
        <p class="text-base leading-relaxed text-cloudy dark:text-cloudy">
          Bootstrapped and scaled a high-availability infrastructure network to profitability within 14 months, serving global clients.
        </p>
        <div class="flex gap-2 flex-wrap">
          <span class="text-xs border border-crail/30 text-crail px-3 py-1 rounded-full">Infrastructure</span>
          <span class="text-xs border border-crail/30 text-crail px-3 py-1 rounded-full">Bootstrapped</span>
          <span class="text-xs border border-crail/30 text-crail px-3 py-1 rounded-full">14 months</span>
        </div>
      </div>

      <!-- Scar Card -->
      <div class="bg-pampas dark:bg-dark-bg-alt border border-cloudy/30 dark:border-cloudy/15 rounded p-8 space-y-5">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-full bg-cloudy/20 flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-cloudy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
          </div>
          <span class="text-xs font-mono tracking-widest text-cloudy uppercase">The Scar</span>
        </div>
        <h3 class="text-xl font-serif font-semibold text-dark-accent dark:text-pampas">The Spectacular Failure</h3>
        <p class="text-base leading-relaxed text-cloudy dark:text-cloudy">
          Poured 8 months and significant capital into a consumer SaaS product that went to absolute zero. The lesson: <span class="text-dark-accent dark:text-pampas font-medium">Distribution always beats clean code.</span>
        </p>
        <div class="flex gap-2 flex-wrap">
          <span class="text-xs border border-cloudy/40 text-cloudy px-3 py-1 rounded-full">SaaS</span>
          <span class="text-xs border border-cloudy/40 text-cloudy px-3 py-1 rounded-full">8 months</span>
          <span class="text-xs border border-cloudy/40 text-cloudy px-3 py-1 rounded-full">Hard lesson</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  DISPATCHES                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-xs font-mono tracking-widest text-cloudy uppercase mb-4">— Latest Writing</p>
    <h2 class="text-3xl font-serif font-semibold text-dark-accent dark:text-pampas mb-12">Dispatches from the Trenches</h2>

    <div class="divide-y divide-cloudy/20 dark:divide-cloudy/10">
      {[
        {
          date: 'Mar 2024',
          title: 'The distribution trap of 2024',
          desc: 'Why every founder I know is building perfect products that no one finds — and what I learned the hard way about growth before code.',
          tag: 'Distribution',
        },
        {
          date: 'Jan 2024',
          title: 'Why I stopped trading time for money',
          desc: 'The exact moment I realized hourly billing was a ceiling, not a floor, and the mental shift that unlocked leverage.',
          tag: 'Leverage',
        },
        {
          date: 'Nov 2023',
          title: 'Infrastructure lessons from a failed launch',
          desc: 'Eight months of architecture decisions, what held up and what collapsed under real-world load. A technical post-mortem.',
          tag: 'Infrastructure',
        },
      ].map((post) => (
        <article class="group py-8 flex flex-col sm:flex-row gap-6 items-start cursor-pointer">
          <div class="shrink-0 w-20 hidden sm:block pt-1">
            <span class="text-xs font-mono text-cloudy">{post.date}</span>
          </div>
          <div class="flex-1 space-y-2">
            <div class="flex items-baseline gap-3 flex-wrap">
              <h3 class="text-lg font-serif font-semibold text-dark-accent dark:text-pampas group-hover:text-crail transition-colors duration-200">{post.title}</h3>
              <span class="text-xs font-mono border border-cloudy/30 text-cloudy px-2 py-0.5 rounded-full">{post.tag}</span>
            </div>
            <p class="text-sm leading-relaxed text-cloudy">{post.desc}</p>
            <span class="text-xs font-mono text-crail group-hover:text-crail-dark transition-colors duration-200">Read more →</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  LIVE STATUS                                -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-12">
    <div class="bg-pampas dark:bg-dark-bg-alt border border-cloudy/30 dark:border-cloudy/15 rounded px-8 py-6 flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div class="flex items-center gap-3 shrink-0">
        <div class="w-2.5 h-2.5 rounded-full bg-crail shrink-0"></div>
        <span class="text-xs font-mono tracking-widest text-crail uppercase">Now</span>
      </div>
      <div class="w-px h-6 bg-cloudy/30 hidden sm:block"></div>
      <p class="text-base leading-relaxed text-dark-accent dark:text-pampas">
        Currently hyper-focused on scaling high-availability networks and writing about the reality of internet business.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-cloudy/30 dark:border-cloudy/15" />
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  CTA                                        -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <p class="text-xs font-mono tracking-widest text-cloudy uppercase mb-6">— Let's talk</p>
    <h2 class="text-4xl md:text-5xl font-serif font-semibold text-dark-accent dark:text-pampas mb-6 leading-tight">
      Let's build something real.
    </h2>
    <p class="text-lg text-cloudy max-w-md mx-auto mb-10">
      No fluff, no buzzwords. If you're working on something serious in IT infrastructure or internet business, I'm interested.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
      <a
        href="mailto:hello@example.com"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-crail hover:bg-crail-dark text-white font-sans font-medium text-sm rounded transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Email Me
      </a>

      <div class="flex items-center gap-6">
        <a
          href="https://twitter.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cloudy hover:text-crail transition-colors duration-200 text-sm font-mono flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.261 5.636 5.903-5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Twitter
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cloudy hover:text-crail transition-colors duration-200 text-sm font-mono flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
