---
import BaseLayout from '../layouts/BaseLayout.astro';

interface TimelineEvent {
  year: string;
  type: 'win' | 'loss' | 'neutral';
  title: string;
  body: string;
}

const timeline: TimelineEvent[] = [
  {
    year: '2018',
    type: 'neutral',
    title: 'Year Zero — The decision to start',
    body: 'Still working full-time in IT. Started my first online venture — an e-commerce store with no real edge, running paid traffic I couldn\'t afford to lose. Paid an expensive education in unit economics, ad platforms, and why copying someone else\'s playbook rarely works. Ended the year with a clearer picture and a thinner wallet.',
  },
  {
    year: '2019',
    type: 'win',
    title: 'First consistent online income',
    body: 'Rebuilt the e-commerce approach from scratch with a sharper niche and better margin discipline. Started generating consistent, if modest, monthly revenue. Simultaneously scaled IT freelancing to international clients — the first time both streams were working at the same time.',
  },
  {
    year: '2019',
    type: 'loss',
    title: 'First partnership implosion',
    body: 'Entered a joint venture with misaligned incentives and no proper agreement. It collapsed badly. Expensive lesson in vetting partners, writing contracts, and the cost of moving fast without structure. Never repeated this category of mistake.',
  },
  {
    year: '2020',
    type: 'win',
    title: 'COVID-era IT consulting surge',
    body: 'When the world went remote, IT infrastructure demand exploded. Expanded managed services offering to cover remote workforce setup, VPN architecture, and endpoint security. Biggest revenue year in IT consulting to that point. Online income diversified into multiple smaller streams running in parallel.',
  },
  {
    year: '2021',
    type: 'win',
    title: 'Peak consulting month — and a product failure',
    body: 'Hit the highest single month in IT consulting revenue. But also launched a digital product without proper validation — built something nobody actually wanted. Watched months of build time generate almost zero sales. Pivotal lesson: validate the demand before writing a line of code or a word of copy.',
  },
  {
    year: '2022',
    type: 'loss',
    title: 'Trend-chasing, badly',
    body: 'Allocated time and capital to a platform play that underestimated how competitive the space was. Lost both the money and six months of focus. The failure itself wasn\'t catastrophic — the opportunity cost was. Stopped chasing markets and started doubling down on what was already working.',
  },
  {
    year: '2022',
    type: 'neutral',
    title: 'Exited first e-commerce venture',
    body: 'Wound down the original e-commerce store after the market conditions and my own focus shifted. Left on my own terms, which felt different than failing. Reinvested the mental bandwidth into IT and a new content direction.',
  },
  {
    year: '2023',
    type: 'neutral',
    title: 'Consolidation — fewer bets, deeper commitment',
    body: 'Consolidated to two main income streams and stopped spreading thin across five mediocre ones. Started writing privately about everything I\'d learned — not for an audience, just to think clearly. That writing became the foundation for this site.',
  },
  {
    year: '2024',
    type: 'win',
    title: 'Building in public — this site',
    body: 'Decided to publish the writing. Not as a "content creator" — as someone with 8+ years of actual data about what building online looks and feels like. IT consulting continues. The personal brand is the new layer.',
  },
  {
    year: '2025–26',
    type: 'neutral',
    title: 'You\'re reading this now',
    body: 'The work continues. New experiments. Refinements to what\'s working. Ongoing writing. If you\'re here, you\'re somewhere in the middle of the same kind of journey — I hope something here is useful.',
  },
];

const dotClass: Record<TimelineEvent['type'], string> = {
  win:     'bg-emerald-400 ring-emerald-400/20',
  loss:    'bg-rose-400    ring-rose-400/20',
  neutral: 'bg-slate-600   ring-slate-600/20',
};

const labelClass: Record<TimelineEvent['type'], string> = {
  win:     'text-emerald-400',
  loss:    'text-rose-400',
  neutral: 'text-slate-600',
};

const labelText: Record<TimelineEvent['type'], string> = {
  win:     'win',
  loss:    'loss',
  neutral: 'pivot',
};
---

<BaseLayout
  title="Journey"
  description="A raw, transparent timeline of my business wins and failures from 2018 to now."
>
  <div class="max-w-3xl mx-auto px-6 pt-20 pb-28">

    <!-- Header -->
    <header class="mb-16 reveal">
      <p class="font-mono text-xs text-cyan-400 uppercase tracking-[0.22em] mb-4">The Journey</p>
      <h1 class="text-3xl sm:text-4xl font-black text-slate-100 mb-5 tracking-tight">
        The Unfiltered Timeline
      </h1>
      <p class="text-[17px] text-slate-500 leading-relaxed max-w-xl">
        Eight-plus years of building things online. Every significant win, every expensive failure,
        and every pivot — in order, without spin.
      </p>

      <!-- Legend -->
      <div class="flex flex-wrap items-center gap-5 mt-8 font-mono text-xs text-slate-600">
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span> Win
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-rose-400 inline-block"></span> Loss
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-slate-600 inline-block"></span> Pivot / Milestone
        </span>
      </div>
    </header>

    <!-- Timeline -->
    <div class="relative reveal">

      <!-- Vertical line -->
      <div class="absolute left-[7px] top-2 bottom-0 w-px bg-slate-800/80 sm:left-[15px]"></div>

      <div class="space-y-12">
        {timeline.map(event => (
          <div class="relative pl-8 sm:pl-14">

            <!-- Dot -->
            <div class={`absolute left-0 sm:left-2 top-1.5 w-3.5 h-3.5 rounded-full ring-4 shrink-0 ${dotClass[event.type]}`}></div>

            <!-- Year badge -->
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="font-mono text-sm font-bold text-slate-300">{event.year}</span>
              <span class={`font-mono text-[11px] uppercase tracking-wider ${labelClass[event.type]}`}>
                {labelText[event.type]}
              </span>
            </div>

            <!-- Content -->
            <h3 class="text-base font-bold text-slate-100 mb-2 leading-snug">{event.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{event.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom note -->
    <div class="mt-20 pt-8 border-t border-slate-800/70 reveal">
      <p class="text-sm text-slate-600 leading-relaxed max-w-lg">
        <span class="text-slate-500 font-medium">A note on the format:</span> This timeline is intentionally written from memory and reflection, not polished PR copy.
        The numbers, the missteps, and the recoveries are all real.
        Future entries will go deeper as I publish more on <a href="/writing" class="text-cyan-400 hover:text-cyan-300 transition-colors">the writing page</a>.
      </p>
    </div>

  </div>
</BaseLayout>
